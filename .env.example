# Copy this file to .env and fill in your values
# Only BASE_MODEL_NAME and ADAPTER_PATH need to change after each retrain

# Model paths (update after each retrain)
BASE_MODEL_NAME=Salesforce/codegen-350M-multi
ADAPTER_PATH=trained_model/final_model

# Model version label (shown in /health response)
MODEL_VERSION=v1

# FIM tokens (match what was used during training)
FIM_PREFIX=<fim_prefix>
FIM_SUFFIX=<fim_suffix>
FIM_MIDDLE=<fim_middle>

# Inference limits
MAX_INPUT_LENGTH=512
DEFAULT_MAX_NEW_TOKENS=30

# Database
DB_PATH=ratings.db
